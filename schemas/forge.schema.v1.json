{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.draigara.com/forge/forge.schema.v1.json",
  "title": "Draigara Forge repository configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "marketplace"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "marketplace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "minLength": 1,
          "maxLength": 64
        }
      }
    }
  }
}
