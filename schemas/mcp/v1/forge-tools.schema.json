{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.draigara.dev/forge/mcp/v1/forge-tools.schema.json",
  "title": "Forge MCP v1 tool result",
  "oneOf": [
    { "$ref": "#/$defs/environment" },
    { "$ref": "#/$defs/marketplaceList" },
    { "$ref": "#/$defs/repositoryInspection" },
    { "$ref": "#/$defs/repositoryInitialization" },
    { "$ref": "#/$defs/candidates" },
    { "$ref": "#/$defs/installation" },
    { "$ref": "#/$defs/status" },
    { "$ref": "#/$defs/error" }
  ],
  "$defs": {
    "toolRequest": {
      "oneOf": [
        { "$ref": "#/$defs/environmentRequest" },
        { "$ref": "#/$defs/marketplaceListRequest" },
        { "$ref": "#/$defs/repositoryInspectRequest" },
        { "$ref": "#/$defs/repositoryInitializeRequest" },
        { "$ref": "#/$defs/marketplaceCandidatesRequest" },
        { "$ref": "#/$defs/installationApplyRequest" },
        { "$ref": "#/$defs/statusRequest" }
      ]
    },
    "emptyArguments": { "type": "object", "additionalProperties": false },
    "repositoryArguments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositoryRoot"],
      "properties": { "repositoryRoot": { "type": "string", "minLength": 1, "maxLength": 4096 } }
    },
    "environmentRequest": {
      "type": "object", "additionalProperties": false, "required": ["tool", "arguments"],
      "properties": { "tool": { "const": "forge_environment_inspect" }, "arguments": { "$ref": "#/$defs/emptyArguments" } }
    },
    "marketplaceListRequest": {
      "type": "object", "additionalProperties": false, "required": ["tool", "arguments"],
      "properties": { "tool": { "const": "forge_marketplace_list" }, "arguments": { "$ref": "#/$defs/emptyArguments" } }
    },
    "repositoryInspectRequest": {
      "type": "object", "additionalProperties": false, "required": ["tool", "arguments"],
      "properties": { "tool": { "const": "forge_repository_inspect" }, "arguments": { "$ref": "#/$defs/repositoryArguments" } }
    },
    "repositoryInitializeRequest": {
      "type": "object", "additionalProperties": false, "required": ["tool", "arguments"],
      "properties": {
        "tool": { "const": "forge_repository_initialize" },
        "arguments": {
          "type": "object", "additionalProperties": false, "required": ["repositoryRoot", "marketplaceId"],
          "properties": {
            "repositoryRoot": { "type": "string", "minLength": 1, "maxLength": 4096 },
            "marketplaceId": { "type": "string", "minLength": 1, "maxLength": 64 }
          }
        }
      }
    },
    "marketplaceCandidatesRequest": {
      "type": "object", "additionalProperties": false, "required": ["tool", "arguments"],
      "properties": {
        "tool": { "const": "forge_marketplace_candidates" },
        "arguments": {
          "type": "object", "additionalProperties": false, "required": ["repositoryRoot"],
          "properties": {
            "repositoryRoot": { "type": "string", "minLength": 1, "maxLength": 4096 },
            "query": { "type": "string", "maxLength": 512 }
          }
        }
      }
    },
    "installationApplyRequest": {
      "type": "object", "additionalProperties": false, "required": ["tool", "arguments"],
      "properties": {
        "tool": { "const": "forge_installation_apply" },
        "arguments": {
          "type": "object", "additionalProperties": false,
          "required": ["repositoryRoot", "evaluationId", "candidateIds", "targets", "confirmed"],
          "properties": {
            "repositoryRoot": { "type": "string", "minLength": 1, "maxLength": 4096 },
            "evaluationId": { "type": "string", "minLength": 1, "maxLength": 128 },
            "candidateIds": { "type": "array", "minItems": 1, "maxItems": 128, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
            "targets": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "enum": ["codex", "claude", "copilot"] } },
            "confirmed": { "const": true }
          }
        }
      }
    },
    "statusRequest": {
      "type": "object", "additionalProperties": false, "required": ["tool", "arguments"],
      "properties": { "tool": { "const": "forge_status" }, "arguments": { "$ref": "#/$defs/repositoryArguments" } }
    },

    "contractVersion": { "const": "1.0" },
    "forgeConfiguration": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["schemaVersion", "marketplace"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "marketplace": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id"],
          "properties": { "id": { "type": "string", "minLength": 1, "maxLength": 64 } }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "forge", "runtime", "machine", "homeDirectory"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/contractVersion" },
        "forge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "channel", "commit"],
          "properties": {
            "version": { "type": "string" },
            "channel": { "enum": ["local", "preview", "stable"] },
            "commit": { "type": "string" }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["node", "platform", "architecture"],
          "properties": {
            "node": { "type": "string" },
            "platform": { "type": "string" },
            "architecture": { "type": "string" }
          }
        },
        "machine": { "type": "string" },
        "homeDirectory": { "type": "string" }
      }
    },
    "marketplace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "origin", "addedAt", "forgeVersion", "apmVersion"],
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "origin": { "enum": ["forge-created", "adopted"] },
        "addedAt": { "type": "string", "format": "date-time" },
        "forgeVersion": { "type": "string" },
        "apmVersion": { "type": "string" }
      }
    },
    "marketplaceList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "marketplaces"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/contractVersion" },
        "marketplaces": { "type": "array", "items": { "$ref": "#/$defs/marketplace" } }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filesScanned", "truncated", "manifests", "documents"],
      "properties": {
        "filesScanned": { "type": "integer", "minimum": 0, "maximum": 2000 },
        "truncated": { "type": "boolean" },
        "manifests": { "type": "array", "items": { "type": "string" } },
        "documents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "repositoryInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "repositoryRoot", "configuration", "evidence"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/contractVersion" },
        "repositoryRoot": { "type": "string" },
        "configuration": { "$ref": "#/$defs/forgeConfiguration" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "repositoryInitialization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "repositoryRoot", "created", "configuration"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/contractVersion" },
        "repositoryRoot": { "type": "string" },
        "created": { "type": "boolean" },
        "configuration": { "$ref": "#/$defs/forgeConfiguration" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "version", "tags", "scope", "kind", "compatibleTargets"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "scope": { "enum": ["global", "repository"] },
        "kind": { "enum": ["plugin", "skill", "package"] },
        "compatibleTargets": { "type": "array", "items": { "enum": ["codex", "claude", "copilot"] } }
      }
    },
    "candidates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "evaluationId", "marketplaceId", "catalogDigest", "candidates"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/contractVersion" },
        "evaluationId": { "type": "string" },
        "marketplaceId": { "type": "string" },
        "catalogDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "candidates": { "type": "array", "items": { "$ref": "#/$defs/candidate" } }
      }
    },
    "installation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "repositoryRoot", "installed", "targets", "verified"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/contractVersion" },
        "repositoryRoot": { "type": "string" },
        "installed": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "targets": { "type": "array", "minItems": 1, "items": { "enum": ["codex", "claude", "copilot"] } },
        "verified": { "const": true }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "repositoryRoot", "configuration", "apm"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/contractVersion" },
        "repositoryRoot": { "type": "string" },
        "configuration": { "$ref": "#/$defs/forgeConfiguration" },
        "apm": {
          "type": "object",
          "additionalProperties": false,
          "required": ["manifest", "lockfile"],
          "properties": {
            "manifest": { "type": "boolean" },
            "lockfile": { "type": "boolean" }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^FORGE_[A-Z0-9_]+$" },
        "message": { "type": "string" }
      }
    }
  }
}
